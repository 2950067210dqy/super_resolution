    "    \"    }\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"训练和评估LeNet-5模型\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
