    "    \"   \\\"outputs\\\": [],\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"b1 = nn.Sequential(nn.Conv2d(1, 64, kernel_size=7, stride=2, padding=3),\\\\n\\\",\\n\",\n",
    "    \"    \\\"                   nn.BatchNorm2d(64), nn.ReLU(),\\\\n\\\",\\n\",\n",
    "    \"    \\\"                   nn.MaxPool2d(kernel_size=3, stride=2, padding=1))\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def resnet_block(input_channels, num_channels, num_residuals,\\\\n\\\",\\n\",\n",
    "    \"    \\\"                 first_block=False):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    blk = []\\\\n\\\",\\n\",\n",
    "    \"    \\\"    for i in range(num_residuals):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        if i == 0 and not first_block:\\\\n\\\",\\n\",\n",
    "    \"    \\\"            blk.append(Residual(input_channels, num_channels,\\\\n\\\",\\n\",\n",
    "    \"    \\\"                                use_1x1conv=True, strides=2))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        else:\\\\n\\\",\\n\",\n",
    "    \"    \\\"            blk.append(Residual(num_channels, num_channels))\\\\n\\\",\\n\",\n",
    "    \"    \\\"    return blk\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"b2 = nn.Sequential(*resnet_block(64, 64, 2, first_block=True))\\\\n\\\",\\n\",\n",
    "    \"    \\\"b3 = nn.Sequential(*resnet_block(64, 128, 2))\\\\n\\\",\\n\",\n",
    "    \"    \\\"b4 = nn.Sequential(*resnet_block(128, 256, 2))\\\\n\\\",\\n\",\n",
    "    \"    \\\"b5 = nn.Sequential(*resnet_block(256, 512, 2))\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"net = nn.Sequential(b1, b2, b3, b4, b5,\\\\n\\\",\\n\",\n",
    "    \"    \\\"                    nn.AdaptiveAvgPool2d((1,1)),\\\\n\\\",\\n\",\n",
    "    \"    \\\"                    nn.Flatten(), nn.Linear(512, 10))\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
