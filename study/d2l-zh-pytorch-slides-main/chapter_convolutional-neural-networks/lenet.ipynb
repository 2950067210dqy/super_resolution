    "    \" \\\"cells\\\": [\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"markdown\\\",\\n\",\n",
    "    \"   \\\"id\\\": \\\"ad4ff7ac\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"slideshow\\\": {\\n\",\n",
    "    \"     \\\"slide_type\\\": \\\"-\\\"\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"# 卷积神经网络（LeNet）\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"LeNet（LeNet-5）由两个部分组成：\\\\n\\\",\\n\",\n",
    "    \"    \\\"卷积编码器和全连接层密集块\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"execution_count\\\": 2,\\n\",\n",
    "    \"   \\\"id\\\": \\\"589980bb\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"origin_pos\\\": 2,\\n\",\n",
    "    \"    \\\"tab\\\": [\\n\",\n",
    "    \"     \\\"pytorch\\\"\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"outputs\\\": [],\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"import torch\\\\n\\\",\\n\",\n",
    "    \"    \\\"from torch import nn\\\\n\\\",\\n\",\n",
    "    \"    \\\"from d2l import torch as d2l\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"net = nn.Sequential(\\\\n\\\",\\n\",\n",
    "    \"    \\\"    nn.Conv2d(1, 6, kernel_size=5, padding=2), nn.Sigmoid(),\\\\n\\\",\\n\",\n",
    "    \"    \\\"    nn.AvgPool2d(kernel_size=2, stride=2),\\\\n\\\",\\n\",\n",
    "    \"    \\\"    nn.Conv2d(6, 16, kernel_size=5), nn.Sigmoid(),\\\\n\\\",\\n\",\n",
    "    \"    \\\"    nn.AvgPool2d(kernel_size=2, stride=2),\\\\n\\\",\\n\",\n",
    "    \"    \\\"    nn.Flatten(),\\\\n\\\",\\n\",\n",
    "    \"    \\\"    nn.Linear(16 * 5 * 5, 120), nn.Sigmoid(),\\\\n\\\",\\n\",\n",
    "    \"    \\\"    nn.Linear(120, 84), nn.Sigmoid(),\\\\n\\\",\\n\",\n",
    "    \"    \\\"    nn.Linear(84, 10))\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"markdown\\\",\\n\",\n",
    "    \"   \\\"id\\\": \\\"e9db4789\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"slideshow\\\": {\\n\",\n",
    "    \"     \\\"slide_type\\\": \\\"slide\\\"\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"检查模型\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"execution_count\\\": 3,\\n\",\n",
    "    \"   \\\"id\\\": \\\"8d4dfb21\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"origin_pos\\\": 7,\\n\",\n",
    "    \"    \\\"tab\\\": [\\n\",\n",
    "    \"     \\\"pytorch\\\"\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"outputs\\\": [\\n\",\n",
    "    \"    {\\n\",\n",
    "    \"     \\\"name\\\": \\\"stdout\\\",\\n\",\n",
    "    \"     \\\"output_type\\\": \\\"stream\\\",\\n\",\n",
    "    \"     \\\"text\\\": [\\n\",\n",
    "    \"      \\\"Conv2d output shape: \\\\t torch.Size([1, 6, 28, 28])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Sigmoid output shape: \\\\t torch.Size([1, 6, 28, 28])\\\\n\\\",\\n\",\n",
    "    \"      \\\"AvgPool2d output shape: \\\\t torch.Size([1, 6, 14, 14])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Conv2d output shape: \\\\t torch.Size([1, 16, 10, 10])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Sigmoid output shape: \\\\t torch.Size([1, 16, 10, 10])\\\\n\\\",\\n\",\n",
    "    \"      \\\"AvgPool2d output shape: \\\\t torch.Size([1, 16, 5, 5])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Flatten output shape: \\\\t torch.Size([1, 400])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Linear output shape: \\\\t torch.Size([1, 120])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Sigmoid output shape: \\\\t torch.Size([1, 120])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Linear output shape: \\\\t torch.Size([1, 84])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Sigmoid output shape: \\\\t torch.Size([1, 84])\\\\n\\\",\\n\",\n",
    "    \"      \\\"Linear output shape: \\\\t torch.Size([1, 10])\\\\n\\\"\\n\",\n",
    "    \"     ]\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"   ],\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"X = torch.rand(size=(1, 1, 28, 28), dtype=torch.float32)\\\\n\\\",\\n\",\n",
    "    \"    \\\"for layer in net:\\\\n\\\",\\n\",\n",
    "    \"    \\\"    X = layer(X)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    print(layer.__class__.__name__,'output shape: \\\\\\\\t',X.shape)\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"markdown\\\",\\n\",\n",
    "    \"   \\\"id\\\": \\\"7f871d98\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"slideshow\\\": {\\n\",\n",
    "    \"     \\\"slide_type\\\": \\\"slide\\\"\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"LeNet在Fashion-MNIST数据集上的表现\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"execution_count\\\": 4,\\n\",\n",
    "    \"   \\\"id\\\": \\\"d13d15dc\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"origin_pos\\\": 11,\\n\",\n",
    "    \"    \\\"tab\\\": [\\n\",\n",
    "    \"     \\\"pytorch\\\"\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"outputs\\\": [],\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"batch_size = 256\\\\n\\\",\\n\",\n",
    "    \"    \\\"train_iter, test_iter = d2l.load_data_fashion_mnist(batch_size=batch_size)\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"markdown\\\",\\n\",\n",
    "    \"   \\\"id\\\": \\\"8f73bc07\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"slideshow\\\": {\\n\",\n",
    "    \"     \\\"slide_type\\\": \\\"slide\\\"\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"对\\\\n\\\",\\n\",\n",
    "    \"    \\\"`evaluate_accuracy`函数进行轻微的修改\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"execution_count\\\": 5,\\n\",\n",
    "    \"   \\\"id\\\": \\\"c868f5c5\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"origin_pos\\\": 15,\\n\",\n",
    "    \"    \\\"tab\\\": [\\n\",\n",
    "    \"     \\\"pytorch\\\"\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"outputs\\\": [],\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"def evaluate_accuracy_gpu(net, data_iter, device=None): \\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"使用GPU计算模型在数据集上的精度\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    if isinstance(net, nn.Module):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        net.eval()\\\\n\\\",\\n\",\n",
    "    \"    \\\"        if not device:\\\\n\\\",\\n\",\n",
    "    \"    \\\"            device = next(iter(net.parameters())).device\\\\n\\\",\\n\",\n",
    "    \"    \\\"    metric = d2l.Accumulator(2)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    with torch.no_grad():\\\\n\\\",\\n\",\n",
    "    \"    \\\"        for X, y in data_iter:\\\\n\\\",\\n\",\n",
    "    \"    \\\"            if isinstance(X, list):\\\\n\\\",\\n\",\n",
    "    \"    \\\"                X = [x.to(device) for x in X]\\\\n\\\",\\n\",\n",
    "    \"    \\\"            else:\\\\n\\\",\\n\",\n",
    "    \"    \\\"                X = X.to(device)\\\\n\\\",\\n\",\n",
    "    \"    \\\"            y = y.to(device)\\\\n\\\",\\n\",\n",
    "    \"    \\\"            metric.add(d2l.accuracy(net(X), y), y.numel())\\\\n\\\",\\n\",\n",
    "    \"    \\\"    return metric[0] / metric[1]\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"markdown\\\",\\n\",\n",
    "    \"   \\\"id\\\": \\\"1d5e3d9d\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"slideshow\\\": {\\n\",\n",
    "    \"     \\\"slide_type\\\": \\\"slide\\\"\\n\",\n",
    "    \"    }\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"为了使用GPU，我们还需要一点小改动\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"execution_count\\\": 6,\\n\",\n",
    "    \"   \\\"id\\\": \\\"8cb06c53\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"origin_pos\\\": 19,\\n\",\n",
    "    \"    \\\"tab\\\": [\\n\",\n",
    "    \"     \\\"pytorch\\\"\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"outputs\\\": [],\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"def train_ch6(net, train_iter, test_iter, num_epochs, lr, device):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    \\\\\\\"\\\\\\\"\\\\\\\"用GPU训练模型(在第六章定义)\\\\\\\"\\\\\\\"\\\\\\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    def init_weights(m):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        if type(m) == nn.Linear or type(m) == nn.Conv2d:\\\\n\\\",\\n\",\n",
    "    \"    \\\"            nn.init.xavier_uniform_(m.weight)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    net.apply(init_weights)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    print('training on', device)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    net.to(device)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    optimizer = torch.optim.SGD(net.parameters(), lr=lr)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    loss = nn.CrossEntropyLoss()\\\\n\\\",\\n\",\n",
    "    \"    \\\"    animator = d2l.Animator(xlabel='epoch', xlim=[1, num_epochs],\\\\n\\\",\\n\",\n",
    "    \"    \\\"                            legend=['train loss', 'train acc', 'test acc'])\\\\n\\\",\\n\",\n",
    "    \"    \\\"    timer, num_batches = d2l.Timer(), len(train_iter)\\\\n\\\",\\n\",\n",
    "    \"    \\\"    for epoch in range(num_epochs):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        metric = d2l.Accumulator(3)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        net.train()\\\\n\\\",\\n\",\n",
    "    \"    \\\"        for i, (X, y) in enumerate(train_iter):\\\\n\\\",\\n\",\n",
    "    \"    \\\"            timer.start()\\\\n\\\",\\n\",\n",
    "    \"    \\\"            optimizer.zero_grad()\\\\n\\\",\\n\",\n",
    "    \"    \\\"            X, y = X.to(device), y.to(device)\\\\n\\\",\\n\",\n",
    "    \"    \\\"            y_hat = net(X)\\\\n\\\",\\n\",\n",
    "    \"    \\\"            l = loss(y_hat, y)\\\\n\\\",\\n\",\n",
    "    \"    \\\"            l.backward()\\\\n\\\",\\n\",\n",
    "    \"    \\\"            optimizer.step()\\\\n\\\",\\n\",\n",
    "    \"    \\\"            with torch.no_grad():\\\\n\\\",\\n\",\n",
    "    \"    \\\"                metric.add(l * X.shape[0], d2l.accuracy(y_hat, y), X.shape[0])\\\\n\\\",\\n\",\n",
    "    \"    \\\"            timer.stop()\\\\n\\\",\\n\",\n",
    "    \"    \\\"            train_l = metric[0] / metric[2]\\\\n\\\",\\n\",\n",
    "    \"    \\\"            train_acc = metric[1] / metric[2]\\\\n\\\",\\n\",\n",
    "    \"    \\\"            if (i + 1) % (num_batches // 5) == 0 or i == num_batches - 1:\\\\n\\\",\\n\",\n",
    "    \"    \\\"                animator.add(epoch + (i + 1) / num_batches,\\\\n\\\",\\n\",\n",
    "    \"    \\\"                             (train_l, train_acc, None))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        test_acc = evaluate_accuracy_gpu(net, test_iter)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        animator.add(epoch + 1, (None, None, test_acc))\\\\n\\\",\\n\",\n",
    "    \"    \\\"    print(f'loss {train_l:.3f}, train acc {train_acc:.3f}, '\\\\n\\\",\\n\",\n",
    "    \"    \\\"          f'test acc {test_acc:.3f}')\\\\n\\\",\\n\",\n",
    "    \"    \\\"    print(f'{metric[2] * num_epochs / timer.sum():.1f} examples/sec '\\\\n\\\",\\n\",\n",
    "    \"    \\\"          f'on {str(device)}')\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
