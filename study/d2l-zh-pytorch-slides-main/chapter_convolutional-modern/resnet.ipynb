    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"import torch\\\\n\\\",\\n\",\n",
    "    \"    \\\"from torch import nn\\\\n\\\",\\n\",\n",
    "    \"    \\\"from torch.nn import functional as F\\\\n\\\",\\n\",\n",
    "    \"    \\\"from d2l import torch as d2l\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"class Residual(nn.Module):  \\\\n\\\",\\n\",\n",
    "    \"    \\\"    def __init__(self, input_channels, num_channels,\\\\n\\\",\\n\",\n",
    "    \"    \\\"                 use_1x1conv=False, strides=1):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        super().__init__()\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.conv1 = nn.Conv2d(input_channels, num_channels,\\\\n\\\",\\n\",\n",
    "    \"    \\\"                               kernel_size=3, padding=1, stride=strides)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.conv2 = nn.Conv2d(num_channels, num_channels,\\\\n\\\",\\n\",\n",
    "    \"    \\\"                               kernel_size=3, padding=1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        if use_1x1conv:\\\\n\\\",\\n\",\n",
    "    \"    \\\"            self.conv3 = nn.Conv2d(input_channels, num_channels,\\\\n\\\",\\n\",\n",
    "    \"    \\\"                                   kernel_size=1, stride=strides)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        else:\\\\n\\\",\\n\",\n",
    "    \"    \\\"            self.conv3 = None\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.bn1 = nn.BatchNorm2d(num_channels)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.bn2 = nn.BatchNorm2d(num_channels)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    def forward(self, X):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        Y = F.relu(self.bn1(self.conv1(X)))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        Y = self.bn2(self.conv2(Y))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        if self.conv3:\\\\n\\\",\\n\",\n",
    "    \"    \\\"            X = self.conv3(X)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        Y += X\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return F.relu(Y)\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
