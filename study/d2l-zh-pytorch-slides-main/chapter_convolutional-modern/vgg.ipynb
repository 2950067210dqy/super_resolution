    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"conv_arch = ((1, 64), (1, 128), (2, 256), (2, 512), (2, 512))\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def vgg(conv_arch):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    conv_blks = []\\\\n\\\",\\n\",\n",
    "    \"    \\\"    in_channels = 1\\\\n\\\",\\n\",\n",
    "    \"    \\\"    for (num_convs, out_channels) in conv_arch:\\\\n\\\",\\n\",\n",
    "    \"    \\\"        conv_blks.append(vgg_block(num_convs, in_channels, out_channels))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        in_channels = out_channels\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    return nn.Sequential(\\\\n\\\",\\n\",\n",
    "    \"    \\\"        *conv_blks, nn.Flatten(),\\\\n\\\",\\n\",\n",
    "    \"    \\\"        nn.Linear(out_channels * 7 * 7, 4096), nn.ReLU(), nn.Dropout(0.5),\\\\n\\\",\\n\",\n",
    "    \"    \\\"        nn.Linear(4096, 4096), nn.ReLU(), nn.Dropout(0.5),\\\\n\\\",\\n\",\n",
    "    \"    \\\"        nn.Linear(4096, 10))\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"net = vgg(conv_arch)\\\"\\n\",\n",
