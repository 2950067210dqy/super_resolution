    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"# 汇聚层\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"实现汇聚层的前向传播\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
    "    \"  {\\n\",\n",
    "    \"   \\\"cell_type\\\": \\\"code\\\",\\n\",\n",
    "    \"   \\\"execution_count\\\": 3,\\n\",\n",
    "    \"   \\\"id\\\": \\\"fe35adac\\\",\\n\",\n",
    "    \"   \\\"metadata\\\": {\\n\",\n",
    "    \"    \\\"origin_pos\\\": 4,\\n\",\n",
    "    \"    \\\"tab\\\": [\\n\",\n",
    "    \"     \\\"pytorch\\\"\\n\",\n",
    "    \"    ]\\n\",\n",
    "    \"   },\\n\",\n",
    "    \"   \\\"outputs\\\": [],\\n\",\n",
    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"import torch\\\\n\\\",\\n\",\n",
    "    \"    \\\"from torch import nn\\\\n\\\",\\n\",\n",
    "    \"    \\\"from d2l import torch as d2l\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"def pool2d(X, pool_size, mode='max'):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    p_h, p_w = pool_size\\\\n\\\",\\n\",\n",
    "    \"    \\\"    Y = torch.zeros((X.shape[0] - p_h + 1, X.shape[1] - p_w + 1))\\\\n\\\",\\n\",\n",
    "    \"    \\\"    for i in range(Y.shape[0]):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        for j in range(Y.shape[1]):\\\\n\\\",\\n\",\n",
    "    \"    \\\"            if mode == 'max':\\\\n\\\",\\n\",\n",
    "    \"    \\\"                Y[i, j] = X[i: i + p_h, j: j + p_w].max()\\\\n\\\",\\n\",\n",
    "    \"    \\\"            elif mode == 'avg':\\\\n\\\",\\n\",\n",
    "    \"    \\\"                Y[i, j] = X[i: i + p_h, j: j + p_w].mean()\\\\n\\\",\\n\",\n",
    "    \"    \\\"    return Y\\\"\\n\",\n",
    "    \"   ]\\n\",\n",
    "    \"  },\\n\",\n",
