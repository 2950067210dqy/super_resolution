    "    \"   \\\"source\\\": [\\n\",\n",
    "    \"    \\\"import torch\\\\n\\\",\\n\",\n",
    "    \"    \\\"from torch import nn\\\\n\\\",\\n\",\n",
    "    \"    \\\"from torch.nn import functional as F\\\\n\\\",\\n\",\n",
    "    \"    \\\"from d2l import torch as d2l\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"class Inception(nn.Module):\\\\n\\\",\\n\",\n",
    "    \"    \\\"    def __init__(self, in_channels, c1, c2, c3, c4, **kwargs):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        super(Inception, self).__init__(**kwargs)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.p1_1 = nn.Conv2d(in_channels, c1, kernel_size=1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.p2_1 = nn.Conv2d(in_channels, c2[0], kernel_size=1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.p2_2 = nn.Conv2d(c2[0], c2[1], kernel_size=3, padding=1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.p3_1 = nn.Conv2d(in_channels, c3[0], kernel_size=1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.p3_2 = nn.Conv2d(c3[0], c3[1], kernel_size=5, padding=2)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.p4_1 = nn.MaxPool2d(kernel_size=3, stride=1, padding=1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"        self.p4_2 = nn.Conv2d(in_channels, c4, kernel_size=1)\\\\n\\\",\\n\",\n",
    "    \"    \\\"\\\\n\\\",\\n\",\n",
    "    \"    \\\"    def forward(self, x):\\\\n\\\",\\n\",\n",
    "    \"    \\\"        p1 = F.relu(self.p1_1(x))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        p2 = F.relu(self.p2_2(F.relu(self.p2_1(x))))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        p3 = F.relu(self.p3_2(F.relu(self.p3_1(x))))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        p4 = F.relu(self.p4_2(self.p4_1(x)))\\\\n\\\",\\n\",\n",
    "    \"    \\\"        return torch.cat((p1, p2, p3, p4), dim=1)\\\"\\n\",\n",
