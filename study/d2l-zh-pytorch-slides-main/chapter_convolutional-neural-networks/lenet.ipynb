    "    \"      \\\"loss 0.480, train acc 0.816, test acc 0.814\\\\n\\\",\\n\",\n",
    "    \"      \\\"3125.0 examples/sec on cuda:0\\\\n\\\"\\n\",\n",
    "    \"     ]\\n\",\n",
